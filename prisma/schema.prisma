generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WhatsappConnection {
  id                 String    @id @default(uuid())
  wabaId             String
  phoneNumberId      String    @unique
  accessToken        String
  displayPhoneNumber String?
  enabled            Boolean   @default(true)
  mode               String    @default("REVIEW")
  pausedUntil        DateTime?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  businessProfile    BusinessProfile?
  conversations      Conversation[]

  @@map("whatsapp_connections")
}

model WhatsappMessage {
  id             String   @id @default(uuid())
  phoneNumberId  String
  direction      String
  fromNumber     String?
  toNumber       String?
  waMessageId    String?
  text           String?
  rawPayload     Json?
  status         String   @default("RECEIVED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phoneNumberId, createdAt])
  @@index([waMessageId])
  @@map("whatsapp_messages")
}

model WhatsappDraft {
  id             String   @id @default(uuid())
  phoneNumberId  String
  inboundMsgId   String?
  toNumber       String
  text           String
  createdBy      String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phoneNumberId, createdAt])
  @@map("whatsapp_drafts")
}

model WhatsappWebhookEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  method      String
  headersJson Json?
  queryJson   Json?
  bodyJson    Json?
  rawBody     String?
  note        String?

  @@index([createdAt])
  @@map("whatsapp_webhook_events")
}

model Niche {
  id        String   @id
  label     String
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template         NicheTemplate?
  businessProfiles BusinessProfile[]

  @@map("niches")
}

model NicheTemplate {
  id           String   @id @default(uuid())
  nicheId      String   @unique
  templateJson Json
  updatedAt    DateTime @updatedAt

  niche Niche @relation(fields: [nicheId], references: [id])

  @@map("niche_templates")
}

model BusinessProfile {
  id                 String   @id @default(uuid())
  connectionId       String   @unique
  nicheId            String?
  businessName       String?
  languagePreference String   @default("en")
  tonePreference     String   @default("friendly")
  handoffRules       Json     @default("{}")
  intakeAnswers      Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connection       WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  niche            Niche?             @relation(fields: [nicheId], references: [id])
  knowledgeSources KnowledgeSource[]
  faqItems         FAQItem[]
  products         ProductOrService[]
  policies         Policies?

  @@map("business_profiles")
}

enum KnowledgeSourceType {
  CATALOG
  FAQ
  POLICIES
  WEBSITE
  DOCUMENT
  NOTES
}

model KnowledgeSource {
  id          String              @id @default(uuid())
  businessId  String
  type        KnowledgeSourceType
  title       String
  contentText String
  metaJson    Json                @default("{}")
  isEnabled   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("knowledge_sources")
}

model FAQItem {
  id         String   @id @default(uuid())
  businessId String
  question   String
  answer     String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("faq_items")
}

model ProductOrService {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  price       Float?
  currency    String   @default("KES")
  description String?
  category    String?
  isActive    Boolean  @default(true)
  sku         String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("products_services")
}

model Policies {
  id                  String   @id @default(uuid())
  businessId          String   @unique
  returnsPolicyText   String?
  warrantyPolicyText  String?
  deliveryPolicyText  String?
  paymentMethodsJson  Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("policies")
}

model Conversation {
  id            String   @id @default(uuid())
  connectionId  String
  customerPhone String
  status        String   @default("active")
  needsHuman    Boolean  @default(false)
  escalationReason String?
  messageHistory Json    @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  connection WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, customerPhone])
  @@map("conversations")
}

model Admin {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  salt             String
  name             String
  activeBusinessId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  restaurant     Restaurant?
  businesses     Business[]     @relation("OwnerAdmin")
  activeBusiness Business?      @relation("ActiveBusiness", fields: [activeBusinessId], references: [id], onDelete: SetNull)

  @@map("admins")
}

enum BusinessType {
  RESTAURANT
  RETAIL
  CLINIC
  SALON
  GOV
  OTHER
}

model Business {
  id                     String       @id @default(uuid())
  ownerAdminId           String
  type                   BusinessType
  name                   String
  phone                  String?
  address                String?
  description            String?
  logoUrl                String?
  colors                 Json         @default("{}")
  settings               Json         @default("{}")
  legacyRestaurantId     String?      @unique
  uiLanguage             String       @default("en")
  incomingTranslateTo    String       @default("en")
  outgoingTranslateTo    String       @default("en")
  autoTranslateIncoming  Boolean      @default(true)
  autoTranslateOutgoing  Boolean      @default(false)
  plan                   String       @default("free")
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  ownerAdmin          Admin                   @relation("OwnerAdmin", fields: [ownerAdminId], references: [id], onDelete: Cascade)
  adminsWithActive    Admin[]                 @relation("ActiveBusiness")
  catalogCategories   CatalogCategory[]
  catalogItems        CatalogItem[]
  messages            Message[]
  translationUsage    TranslationUsageDaily[]

  @@index([ownerAdminId])
  @@map("businesses")
}

model CatalogCategory {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  description String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  catalogItems CatalogItem[]

  @@index([businessId])
  @@map("catalog_categories")
}

model CatalogItem {
  id          String   @id @default(uuid())
  businessId  String
  categoryId  String?
  name        String
  price       Float?
  currency    String   @default("KES")
  description String?
  imageUrl    String?
  isAvailable Boolean  @default(true)
  position    Int      @default(0)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  category CatalogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([categoryId])
  @@map("catalog_items")
}

model Restaurant {
  id          String   @id @default(uuid())
  adminId     String   @unique
  name        String
  phone       String?
  address     String?
  description String?
  logoUrl     String?
  colors      Json     @default("{}")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin      Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  categories MenuCategory[]
  menuItems  MenuItem[]
  orders     Order[]

  @@map("restaurants")
}

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Float
  currency     String   @default("KES")
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("menu_items")
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  delivered
  cancelled
}

model Order {
  id            String      @id @default(uuid())
  restaurantId  String
  businessId    String?
  status        OrderStatus @default(pending)
  items         Json        @default("[]")
  customerName  String?
  customerPhone String?
  customerEmail String?
  subtotal      Float       @default(0)
  total         Float       @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@map("orders")
}

enum TranslationStatus {
  none
  done
  failed
}

model Message {
  id                String            @id @default(uuid())
  businessId        String
  conversationId    String?
  direction         String            @default("inbound")
  senderPhone       String?
  recipientPhone    String?
  textOriginal      String
  langOriginal      String?
  textTranslated    String?
  langTranslated    String?
  translationStatus TranslationStatus @default(none)
  translationError  String?
  metadata          Json              @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([conversationId])
  @@map("messages")
}

model TranslationCache {
  id             String    @id @default(uuid())
  keyHash        String    @unique
  fromLang       String
  toLang         String
  textOriginal   String
  textTranslated String
  hitCount       Int       @default(0)
  lastHitAt      DateTime?
  createdAt      DateTime  @default(now())

  @@map("translation_cache")
}

model TranslationUsageDaily {
  id         String   @id @default(uuid())
  businessId String
  day        DateTime
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, day])
  @@index([businessId])
  @@map("translation_usage_daily")
}
