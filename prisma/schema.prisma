generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WhatsappConnection {
  id                 String   @id @default(uuid())
  wabaId             String
  phoneNumberId      String   @unique
  accessToken        String
  displayPhoneNumber String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  businessProfile    BusinessProfile?
  conversations      Conversation[]

  @@map("whatsapp_connections")
}

model Niche {
  id        String   @id
  label     String
  version   Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template         NicheTemplate?
  businessProfiles BusinessProfile[]

  @@map("niches")
}

model NicheTemplate {
  id           String   @id @default(uuid())
  nicheId      String   @unique
  templateJson Json
  updatedAt    DateTime @updatedAt

  niche Niche @relation(fields: [nicheId], references: [id])

  @@map("niche_templates")
}

model BusinessProfile {
  id                 String   @id @default(uuid())
  connectionId       String   @unique
  nicheId            String?
  businessName       String?
  languagePreference String   @default("en")
  tonePreference     String   @default("friendly")
  handoffRules       Json     @default("{}")
  intakeAnswers      Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  connection       WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  niche            Niche?             @relation(fields: [nicheId], references: [id])
  knowledgeSources KnowledgeSource[]
  faqItems         FAQItem[]
  products         ProductOrService[]
  policies         Policies?

  @@map("business_profiles")
}

enum KnowledgeSourceType {
  CATALOG
  FAQ
  POLICIES
  WEBSITE
  DOCUMENT
  NOTES
}

model KnowledgeSource {
  id          String              @id @default(uuid())
  businessId  String
  type        KnowledgeSourceType
  title       String
  contentText String
  metaJson    Json                @default("{}")
  isEnabled   Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("knowledge_sources")
}

model FAQItem {
  id         String   @id @default(uuid())
  businessId String
  question   String
  answer     String
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("faq_items")
}

model ProductOrService {
  id          String   @id @default(uuid())
  businessId  String
  name        String
  price       Float?
  currency    String   @default("KES")
  description String?
  category    String?
  isActive    Boolean  @default(true)
  sku         String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("products_services")
}

model Policies {
  id                  String   @id @default(uuid())
  businessId          String   @unique
  returnsPolicyText   String?
  warrantyPolicyText  String?
  deliveryPolicyText  String?
  paymentMethodsJson  Json     @default("[]")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  business BusinessProfile @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("policies")
}

model Conversation {
  id            String   @id @default(uuid())
  connectionId  String
  customerPhone String
  status        String   @default("active")
  needsHuman    Boolean  @default(false)
  escalationReason String?
  messageHistory Json    @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  connection WhatsappConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, customerPhone])
  @@map("conversations")
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  salt         String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant?

  @@map("admins")
}

model Restaurant {
  id          String   @id @default(uuid())
  adminId     String   @unique
  name        String
  phone       String?
  address     String?
  description String?
  logoUrl     String?
  colors      Json     @default("{}")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin      Admin          @relation(fields: [adminId], references: [id], onDelete: Cascade)
  categories MenuCategory[]
  menuItems  MenuItem[]
  orders     Order[]

  @@map("restaurants")
}

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  position     Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems  MenuItem[]

  @@map("menu_categories")
}

model MenuItem {
  id           String   @id @default(uuid())
  restaurantId String
  categoryId   String?
  name         String
  description  String?
  price        Float
  currency     String   @default("KES")
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@map("menu_items")
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  delivered
  cancelled
}

model Order {
  id            String      @id @default(uuid())
  restaurantId  String
  status        OrderStatus @default(pending)
  items         Json        @default("[]")
  customerName  String?
  customerPhone String?
  customerEmail String?
  subtotal      Float       @default(0)
  total         Float       @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("orders")
}
