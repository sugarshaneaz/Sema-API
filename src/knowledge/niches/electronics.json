{
  "key": "electronics",
  "label": { "en": "Electronics Store", "sw": "Duka la Elektroniki" },
  "primer": {
    "en": "You are an AI assistant for an electronics store. Help customers with product inquiries, specifications, pricing, availability, and after-sales support. Always verify current stock and prices before quoting.",
    "sw": "Wewe ni msaidizi wa AI kwa duka la elektroniki. Saidia wateja kuhusu bidhaa, vipimo, bei, upatikanaji, na msaada wa baada ya mauzo. Daima thibitisha hifadhi na bei za sasa kabla ya kunukuu."
  },
  "intents": [
    { "key": "product_specs", "description": { "en": "Customer asks about product specifications", "sw": "Mteja anauliza vipimo vya bidhaa" }, "exampleQuestions": ["What's the screen size?", "Ukubwa wa skrini ni upi?"], "responseTemplate": { "en": "Here are the specifications for {item}:", "sw": "Hizi ni vipimo vya {item}:" } },
    { "key": "compare_products", "description": { "en": "Customer wants to compare products", "sw": "Mteja anataka kulinganisha bidhaa" }, "exampleQuestions": ["Which phone is better?", "Simu ipi ni bora?"], "responseTemplate": { "en": "Let me compare those options for you:", "sw": "Acha nilinganishe chaguo hizo kwako:" } },
    { "key": "warranty_support", "description": { "en": "Customer asks about warranty", "sw": "Mteja anauliza kuhusu dhamana" }, "exampleQuestions": ["What's the warranty?", "Dhamana ni ipi?"], "responseTemplate": { "en": "Let me check the warranty details for {item}.", "sw": "Acha niangalie maelezo ya dhamana ya {item}." } }
  ],
  "onboardingFields": [
    { "key": "main_categories", "type": "multi-select", "required": true, "label": { "en": "Main categories?", "sw": "Aina kuu?" }, "options": [{ "value": "phones", "label": { "en": "Phones", "sw": "Simu" } }, { "value": "accessories", "label": { "en": "Accessories", "sw": "Vifaa" } }, { "value": "tvs", "label": { "en": "TVs", "sw": "Televisheni" } }, { "value": "computers", "label": { "en": "Computers", "sw": "Kompyuta" } }, { "value": "audio", "label": { "en": "Audio", "sw": "Sauti" } }, { "value": "gaming", "label": { "en": "Gaming", "sw": "Michezo" } }, { "value": "smart_home", "label": { "en": "Smart home", "sw": "Nyumba smart" } }, { "value": "other", "label": { "en": "Other", "sw": "Nyingine" } }] },
    { "key": "warranty", "type": "select", "required": true, "label": { "en": "Warranty offered?", "sw": "Dhamana inatolewa?" }, "options": [{ "value": "none", "label": { "en": "None", "sw": "Hakuna" } }, { "value": "store_warranty", "label": { "en": "Store warranty", "sw": "Dhamana ya duka" } }, { "value": "manufacturer_warranty", "label": { "en": "Manufacturer warranty", "sw": "Dhamana ya mtengenezaji" } }] },
    { "key": "repairs_available", "type": "boolean", "required": true, "label": { "en": "Repairs available?", "sw": "Ukarabati unapatikana?" } }
  ],
  "rules": {
    "neverInvent": ["price", "stock", "warranty", "specifications", "eta", "paymentMethods"],
    "escalateIf": ["refund_request", "complaint", "defective_product", "warranty_claim"],
    "style": ["WhatsApp short messages", "technical but accessible", "compare specs side-by-side", "mention warranty details"]
  },
  "templates": {
    "orderConfirm": { "en": "Your order:\n{items}\nTotal: {currency} {total}\n\nPayment method?", "sw": "Agizo lako:\n{items}\nJumla: {currency} {total}\n\nNjia ya malipo?" },
    "availabilityCheck": { "en": "Let me check current stock and pricing for {item}.", "sw": "Acha niangalie hifadhi na bei ya sasa kwa {item}." },
    "quoteRequest": { "en": "For a quote, please specify:\n- Product model\n- Quantity\n- Any accessories needed", "sw": "Kwa nukuu, tafadhali bainisha:\n- Aina ya bidhaa\n- Idadi\n- Vifaa vyovyote vinavyohitajika" }
  }
}
