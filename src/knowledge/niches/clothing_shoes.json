{
  "key": "clothing_shoes",
  "label": { "en": "Clothing & Shoes", "sw": "Nguo na Viatu" },
  "primer": {
    "en": "You are an AI assistant for a clothing and shoes store. Help customers with product inquiries, sizing, availability, pricing, and style recommendations. Always confirm sizes and colors before processing orders.",
    "sw": "Wewe ni msaidizi wa AI kwa duka la nguo na viatu. Saidia wateja kuhusu bidhaa, ukubwa, upatikanaji, bei, na mapendekezo ya mitindo. Daima thibitisha ukubwa na rangi kabla ya kushughulikia maagizo."
  },
  "intents": [
    { "key": "size_inquiry", "description": { "en": "Customer asks about sizes", "sw": "Mteja anauliza kuhusu ukubwa" }, "exampleQuestions": ["Do you have size 42?", "Mna ukubwa wa 42?"], "responseTemplate": { "en": "Let me check available sizes for {item}.", "sw": "Acha niangalie ukubwa unaopatikana kwa {item}." } },
    { "key": "new_arrivals", "description": { "en": "Customer asks about new stock", "sw": "Mteja anauliza kuhusu bidhaa mpya" }, "exampleQuestions": ["What's new?", "Kuna nini kipya?"], "responseTemplate": { "en": "Here are our latest arrivals:", "sw": "Hizi ni bidhaa zetu mpya:" } }
  ],
  "onboardingFields": [
    { "key": "what_you_sell", "type": "multi-select", "required": true, "label": { "en": "What do you sell most?", "sw": "Mnauza nini zaidi?" }, "options": [{ "value": "mens_clothing", "label": { "en": "Men's clothing", "sw": "Nguo za wanaume" } }, { "value": "womens_clothing", "label": { "en": "Women's clothing", "sw": "Nguo za wanawake" } }, { "value": "kids_clothing", "label": { "en": "Kids' clothing", "sw": "Nguo za watoto" } }, { "value": "shoes", "label": { "en": "Shoes", "sw": "Viatu" } }, { "value": "accessories", "label": { "en": "Accessories", "sw": "Vifaa" } }, { "value": "other", "label": { "en": "Other", "sw": "Nyingine" } }] },
    { "key": "exchange_days", "type": "select", "required": true, "label": { "en": "Exchange policy (days allowed)?", "sw": "Sera ya kubadilisha (siku zinazoruhusiwa)?" }, "options": [{ "value": "3_days", "label": { "en": "3 days", "sw": "Siku 3" } }, { "value": "7_days", "label": { "en": "7 days", "sw": "Siku 7" } }, { "value": "14_days", "label": { "en": "14 days", "sw": "Siku 14" } }, { "value": "30_days", "label": { "en": "30 days", "sw": "Siku 30" } }, { "value": "no_exchanges", "label": { "en": "No exchanges", "sw": "Hakuna kubadilisha" } }] },
    { "key": "delivery_available", "type": "boolean", "required": true, "label": { "en": "Delivery available?", "sw": "Uwasilishaji unapatikana?" } },
    { "key": "delivery_areas", "type": "text", "required": false, "label": { "en": "What areas do you deliver to?", "sw": "Mnawasilisha maeneo gani?" }, "visibleIf": { "field": "delivery_available", "value": true } }
  ],
  "rules": {
    "neverInvent": ["price", "stock", "sizes", "colors", "materials", "eta"],
    "escalateIf": ["refund_request", "complaint", "wrong_size", "defective_item"],
    "style": ["WhatsApp short messages", "mention sizes and colors", "confirm order details before payment", "suggest matching items"]
  },
  "templates": {
    "orderConfirm": { "en": "Your order:\n{items}\nSize: {size} | Color: {color}\nTotal: {currency} {total}\n\nConfirm?", "sw": "Agizo lako:\n{items}\nUkubwa: {size} | Rangi: {color}\nJumla: {currency} {total}\n\nThibitisha?" },
    "availabilityCheck": { "en": "Let me check sizes and colors available for {item}.", "sw": "Acha niangalie ukubwa na rangi zinazopatikana kwa {item}." },
    "quoteRequest": { "en": "For bulk/wholesale pricing, please share:\n- Items and quantities\n- Sizes needed", "sw": "Kwa bei ya wingi/jumla, tafadhali shiriki:\n- Bidhaa na idadi\n- Ukubwa unaohitajika" }
  }
}
