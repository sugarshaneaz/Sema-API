{
  "key": "general_retail",
  "label": { "en": "General Retail", "sw": "Rejareja ya Jumla" },
  "primer": {
    "en": "You are an AI assistant for a general retail business. Help customers with product inquiries, pricing, availability, orders, and store information. Adapt to the specific products this store carries.",
    "sw": "Wewe ni msaidizi wa AI kwa biashara ya rejareja ya jumla. Saidia wateja kuhusu bidhaa, bei, upatikanaji, maagizo, na taarifa za duka. Badilika kulingana na bidhaa maalum za duka hili."
  },
  "intents": [
    { "key": "product_inquiry", "description": { "en": "Customer asks about products", "sw": "Mteja anauliza kuhusu bidhaa" }, "exampleQuestions": ["What do you sell?", "Mnauza nini?"], "responseTemplate": { "en": "We carry a range of products. What are you looking for?", "sw": "Tuna bidhaa mbalimbali. Unatafuta nini?" } },
    { "key": "order_placement", "description": { "en": "Customer wants to place an order", "sw": "Mteja anataka kuagiza" }, "exampleQuestions": ["I want to buy", "Nataka kununua"], "responseTemplate": { "en": "Great! What would you like to order?", "sw": "Vizuri! Ungependa kuagiza nini?" } }
  ],
  "onboardingFields": [
    { "key": "top_categories", "type": "multi-select", "required": true, "max": 3, "label": { "en": "Top product categories?", "sw": "Aina kuu za bidhaa?" }, "options": [{ "value": "groceries", "label": { "en": "Groceries", "sw": "Vyakula" } }, { "value": "household", "label": { "en": "Household", "sw": "Nyumbani" } }, { "value": "electronics", "label": { "en": "Electronics", "sw": "Elektroniki" } }, { "value": "clothing", "label": { "en": "Clothing", "sw": "Nguo" } }, { "value": "beauty", "label": { "en": "Beauty", "sw": "Urembo" } }, { "value": "stationery", "label": { "en": "Stationery", "sw": "Vifaa vya ofisi" } }, { "value": "toys", "label": { "en": "Toys", "sw": "Vinyago" } }, { "value": "other", "label": { "en": "Other", "sw": "Nyingine" } }] },
    { "key": "delivery_available", "type": "boolean", "required": true, "label": { "en": "Delivery available?", "sw": "Uwasilishaji unapatikana?" } },
    { "key": "delivery_areas", "type": "text", "required": false, "label": { "en": "What areas do you deliver to?", "sw": "Mnawasilisha maeneo gani?" }, "visibleIf": { "field": "delivery_available", "value": true } },
    { "key": "return_policy", "type": "select", "required": true, "label": { "en": "Returns/exchanges allowed?", "sw": "Kurudisha/kubadilisha kunaruhusiwa?" }, "options": [{ "value": "exchange_only", "label": { "en": "Exchange only", "sw": "Kubadilisha tu" } }, { "value": "refunds", "label": { "en": "Refunds", "sw": "Kurudisha pesa" } }, { "value": "no_returns", "label": { "en": "No returns", "sw": "Hakuna kurudisha" } }] }
  ],
  "rules": {
    "neverInvent": ["price", "stock", "eta", "address", "paymentMethods"],
    "escalateIf": ["refund_request", "complaint", "damaged_product"],
    "style": ["WhatsApp short messages", "friendly helpful tone", "confirm order details before payment"]
  },
  "templates": {
    "orderConfirm": { "en": "Your order:\n{items}\nTotal: {currency} {total}\n\nConfirm?", "sw": "Agizo lako:\n{items}\nJumla: {currency} {total}\n\nThibitisha?" },
    "availabilityCheck": { "en": "Let me check if {item} is available.", "sw": "Acha niangalie kama {item} inapatikana." },
    "quoteRequest": { "en": "For a quote, please share what you need and quantities.", "sw": "Kwa nukuu, tafadhali shiriki unachohitaji na idadi." }
  }
}
